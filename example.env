PORT=4000
NODE_ENV=development

# ── JWT Secrets (generate with: openssl rand -hex 64) ─────────────
JWT_ACCESS_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_another_64_byte_hex_secret

# ── MongoDB ────────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=YourApp

# ── SMS Gateway (Fast2SMS) ─────────────────────────────────────────
FAST2SMS_API_KEY=your_fast2sms_api_key
FAST2SMS_URL=https://www.fast2sms.com/dev/bulkV2

# ── WhatsApp Cloud API (Meta) — service reminders ──────────────────
# Leave blank to disable WhatsApp sends (push notifications still work).
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=

# ── Service-reminder scheduler ─────────────────────────────────────
REMINDER_SCHEDULER_ENABLED=true
REMINDER_SCHEDULER_INTERVAL_MIN=60
# Fallback daily distance (km) used to predict a due date when the
# customer's dailyRunningKm is unknown.
REMINDER_DEFAULT_DAILY_KM=40

# ── Mechanic payroll / bonus ───────────────────────────────────────
# Flat bonus (percent of base salary) when a mechanic completes at least
# PAYROLL_BONUS_THRESHOLD services in a calendar month.
PAYROLL_BONUS_THRESHOLD=100
PAYROLL_BONUS_PERCENT=2

# ── CORS ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── API versioning ─────────────────────────────────────────────────
BACKEND_VERSION=v1

# Plan settings
